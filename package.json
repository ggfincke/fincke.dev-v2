{
  "name": "fincke.dev-v2",
  "private": true,
  "version": "2.8.1",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun run typecheck && bun run bundle",
    "bundle": "vite build",
    "typecheck": "tsc -b --noEmit",
    "ci:check": "bun run format:check && bun run typecheck && bun run test && bun run validate-assets && bun run bundle",
    "lint": "eslint .",
    "preview": "vite preview",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && bun run lint",
    "screenshots": "tsx scripts/screenshots.ts",
    "screenshots:smoke": "tsx scripts/screenshots.ts --smoke",
    "audit:accessibility": "tsx scripts/accessibility.ts",
    "browser:check": "bun run audit:accessibility && bun run lighthouse && bun run screenshots:smoke",
    "check-links": "tsx scripts/check-links.ts",
    "validate-assets": "tsx scripts/validate-assets.ts",
    "content:health": "bun run validate-assets && bun run check-links",
    "lighthouse": "tsx scripts/lighthouse.ts",
    "analyze": "vite-bundle-visualizer --output reports/bundle.html",
    "preversion": "bun scripts/check-changelog.mjs",
    "version": "git add CHANGELOG.md"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.3"
  },
  "prettier": "@ggfincke/prettier-config",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.36.0",
    "@ggfincke/eslint-config": "file:packages/eslint-config",
    "@ggfincke/prettier-config": "file:packages/prettier-config",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "baseline-browser-mapping": "^2.10.25",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "lighthouse": "^12.8.2",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "prettier-plugin-brace-style": "^0.10.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.2"
  }
}
