{
  "name": "fincke.dev-v2",
  "private": true,
  "version": "2.9.6",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun run typecheck && bun run bundle",
    "bundle": "vite build",
    "typecheck": "tsc -b --noEmit",
    "ci:check": "bun run format:check && bun run typecheck && bun run test && bun run validate-assets && bun run bundle",
    "lint": "eslint .",
    "preview": "vite preview",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && bun run lint",
    "screenshots": "bun scripts/screenshots.ts",
    "screenshots:smoke": "bun scripts/screenshots.ts --smoke",
    "audit:accessibility": "bun scripts/accessibility.ts",
    "browser:check": "bun run audit:accessibility && bun run lighthouse && bun run screenshots:smoke",
    "check-links": "bun scripts/check-links.ts",
    "validate-assets": "bun scripts/validate-assets.ts",
    "content:health": "bun run validate-assets && bun run check-links",
    "lighthouse": "bun scripts/lighthouse.ts",
    "analyze": "vite-bundle-visualizer --output reports/bundle.html",
    "preversion": "bun scripts/check-changelog.ts",
    "version": "git add CHANGELOG.md"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "overrides": {
    "playwright-core": "^1.60.0"
  },
  "prettier": "@ggfincke/prettier-config",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@ggfincke/eslint-config": "file:packages/eslint-config",
    "@ggfincke/prettier-config": "file:packages/prettier-config",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "baseline-browser-mapping": "^2.10.40",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "lighthouse": "^12.8.2",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "prettier-plugin-brace-style": "^0.10.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.9"
  }
}
